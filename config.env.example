# ============================================================
# iLO Certificate Renew — Konfiguration
# Kopiere diese Datei nach config.env und passe die Werte an.
# config.env wird NICHT in git eingecheckt (siehe .gitignore).
# ============================================================

# --- iLO Zugangsdaten ---
# Service-Account in iLO (User Administration → Service)
ILO_USER="gustini"
ILO_PASS="CHANGEME"

# --- Ziel-iLO-Hosts ---
# Leerzeichen-getrennte Liste — Hostnamen müssen per DNS auflösbar sein
# und dem CN im Zertifikat entsprechen (z.B. ilo-pve3.gustini-intern.de)
ILO_HOSTS="ilo-pve1.gustini-intern.de ilo-pve2.gustini-intern.de ilo-pve3.gustini-intern.de"

# --- Domain Offensive API Token ---
# Einzustellen unter: Domain Offensive → Domains → Let's Encrypt API-Token
# Wird ausschließlich für DNS-01-Challenge verwendet (acme.sh dns_doapi Plugin)
DO_LETOKEN="CHANGEME"

# --- acme.sh Pfad ---
# Standard nach Installation: /root/.acme.sh/acme.sh
ACME_SH="/root/.acme.sh/acme.sh"

# --- Zertifikat-Details (iLO CSR) ---
ILO_ORG="Gustini GmbH"
ILO_OU="IT"
ILO_CITY="Leipzig"
ILO_STATE="Sachsen"
ILO_COUNTRY="DE"

# --- Renewal-Schwelle in Tagen ---
# Zertifikat wird erneuert wenn weniger als N Tage Restlaufzeit
RENEWAL_DAYS=30

# --- Logging ---
LOG_FILE="/var/log/ilo-cert-renew.log"
